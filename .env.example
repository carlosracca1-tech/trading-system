# ──────────────────────────────────────────────────────────────────────────────
# TRADING SYSTEM — Environment Template
# Copy to .env and fill in your values.
# NEVER commit the actual .env file.
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
TRADING_MODE=dev           # dev | staging | paper | live
DEBUG=false
DRY_RUN=true               # true = log orders but don't send them

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=dev-api-key-change-me           # static API key for internal auth (must match docker-compose)

# ── Database ──────────────────────────────────────────────────────────────────
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://trading:trading_dev_pass@localhost:5433/trading_dev
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30

# ── Broker — Alpaca ───────────────────────────────────────────────────────────
# For dev: leave blank, broker calls are mocked
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# Paper: https://paper-api.alpaca.markets/v2
# Live:  https://api.alpaca.markets/v2
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2

# ── Data — Polygon.io ─────────────────────────────────────────────────────────
POLYGON_API_KEY=

# ── Alerting — Telegram ───────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=json            # json | console (console for local dev readability)

# ── Sentry (optional, leave blank in dev) ─────────────────────────────────────
SENTRY_DSN=

# ──────────────────────────────────────────────────────────────────────────────
# STANDALONE BOTS (standalone_paper_trader.py, standalone_mrev_trader.py)
# These live alongside the services stack and read their own env.
# For the standalone bots, create a separate `.env.paper` (gitignored).
# ──────────────────────────────────────────────────────────────────────────────

# Safety margin over Alpaca buying power. The bot uses at most this fraction
# of reported BP before each buy (protects against slippage / latency).
ALPACA_BP_SAFETY=0.90

# Kill switch. If equity drops more than this fraction below peak equity, the
# bot stops opening new positions (existing positions are not closed).
MAX_DRAWDOWN=0.20

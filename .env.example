# ──────────────────────────────────────────────────────────────────────────────
# TRADING SYSTEM — Environment Template
# Copy to .env and fill in your values.
# NEVER commit the actual .env file.
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
TRADING_MODE=dev           # dev | staging | paper | live
DEBUG=false
DRY_RUN=true               # true = log orders but don't send them

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=dev-api-key-change-me           # static API key for internal auth (must match docker-compose)

# ── Database ──────────────────────────────────────────────────────────────────
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://trading:trading_dev_pass@localhost:5433/trading_dev
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30

# ── Broker — Alpaca ───────────────────────────────────────────────────────────
# For dev: leave blank, broker calls are mocked
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# Paper: https://paper-api.alpaca.markets/v2
# Live:  https://api.alpaca.markets/v2
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2

# ── Data — Polygon.io ─────────────────────────────────────────────────────────
POLYGON_API_KEY=

# ── Alerting — Telegram ───────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=json            # json | console (console for local dev readability)

# ── Sentry (optional, leave blank in dev) ─────────────────────────────────────
SENTRY_DSN=

# ──────────────────────────────────────────────────────────────────────────────
# STANDALONE BOTS (standalone_paper_trader.py, standalone_mrev_trader.py)
# These live alongside the services stack and read their own env.
# For the standalone bots, create a separate `.env.paper` (gitignored).
# ──────────────────────────────────────────────────────────────────────────────

# Safety margin over Alpaca buying power. The bot uses at most this fraction
# of reported BP before each buy (protects against slippage / latency).
ALPACA_BP_SAFETY=0.90

# Kill switch. If equity drops more than this fraction below peak equity, the
# bot stops opening new positions (existing positions are not closed).
MAX_DRAWDOWN=0.20

# Minimum notional (USD) to fire a partial TP. Matches Alpaca's crypto min
# order size. If the calculated partial is below, the bot skips and waits
# for the next trigger / final exit — avoids Alpaca rejecting micro-orders.
PARTIAL_MIN_NOTIONAL_USD=10.0

# ──────────────────────────────────────────────────────────────────────────────
# F1 — Anti-whipsaw cooldowns (post-exit stop/trailing/time)
# ──────────────────────────────────────────────────────────────────────────────
# Tras un exit "negativo" (stop loss, trailing stop, time stop) en un símbolo,
# el bot bloquea la re-entrada por dos razones independientes:
#   1. Temporal: N días hábiles (RFTM) o N horas (MREV) desde el exit.
#   2. Precio: aunque expire el temporal, si el símbolo subió >X% desde el
#      exit, bloquea igual — evita perseguir rebotes que estadísticamente
#      reversionan.
# El cooldown NO se registra después de TPs (re-entrar tras ganancia es válido).

# RFTM (ETF, días hábiles)
RFTM_COOLDOWN_DAYS=5
RFTM_REENTRY_MAX_RUNUP=0.10   # +10% desde el exit

# MREV (cripto, horas)
MREV_COOLDOWN_HOURS=6
MREV_REENTRY_MAX_RUNUP=0.10

# Post-mortem JSONL: cada vez que el cooldown de precio bloquea una entrada,
# se loguea el rebote perdido para que KAIZEN procese qué subidas estamos
# dejando pasar. Path overrideable, default <root>/logs/kaizen_missed_moves.jsonl.
# KAIZEN_MISSED_PATH=

# ──────────────────────────────────────────────────────────────────────────────
# F3.2 — Watchdog healthcheck (cobertura + email alerts)
# ──────────────────────────────────────────────────────────────────────────────
# Cada run del watchdog genera un HealthReport con cobertura
# (expected vs evaluated), sells fallidas, timeouts. Si severity >= warn,
# manda email a EMAIL_TO. Persiste también a logs/kaizen_health.jsonl para
# análisis de tendencias.

# Path override del JSONL (default <root>/logs/kaizen_health.jsonl)
# KAIZEN_HEALTH_PATH=

# Skipear email (útil para testing local que no quiere spamearte)
# WATCHDOG_HEALTH_EMAIL_ENABLED=0

# ──────────────────────────────────────────────────────────────────────────────
# F3.1 — Bracket orders (broker-side safety stops, RFTM only)
# ──────────────────────────────────────────────────────────────────────────────
# Activa el envío de SELL STOP orders en Alpaca después de cada BUY. Si el
# watchdog se cae, Alpaca igual ejecuta el stop. Aplica SOLO a RFTM/ETFs
# — MREV/cripto sigue software-side (Alpaca no soporta bracket en cripto).
#
# Default OFF para activación gradual en paper antes de live. Cuando lo
# prendas, los stops del watchdog siguen activos también (belt + suspenders).
# RFTM_BRACKET_ORDERS_ENABLED=0

# ──────────────────────────────────────────────────────────────────────────────
# TRADE EVENT LOGGING (F5.0 — fuente de verdad para KAIZEN)
# ──────────────────────────────────────────────────────────────────────────────
# _trade_logger persiste CADA evento (BUY/SELL_*) a un JSONL local + best
# effort a Google Sheets. El JSONL es lo que KAIZEN consume.

# Path al JSONL local. En GHA Actions cada workflow setea su propio path
# (logs/trade_events_rftm.jsonl / logs/trade_events_mrev.jsonl). En local
# podés overridear si tu HOME está en FUSE/iCloud que rompa fcntl.
# TRADE_EVENTS_JSONL_PATH=$TMPDIR/trade_events.jsonl

# Skipear el forward a Google Sheets (útil para tests sin tocar la cuenta).
# TRADE_EVENTS_DISABLE_SHEETS=1

# Stdout verbose del logger.
# TRADE_EVENTS_DEBUG=1

# ──────────────────────────────────────────────────────────────────────────────
# GOOGLE SHEETS — Service Account auth (espejo conveniente del JSONL)
# ──────────────────────────────────────────────────────────────────────────────
# Ver scripts/sheets/SETUP.md para crear el Service Account y compartir la
# hoja con el client_email. NO uses el viejo Apps Script Webhook — fue
# reemplazado por Service Account auth (mejor diagnóstico de errores).

# ID del spreadsheet (sale de la URL de la hoja).
SHEETS_SPREADSHEET_ID=

# Contenido COMPLETO del JSON del service account (todo en una línea, las
# newlines del private_key escapadas como \n). En GHA va como secret.
SHEETS_SERVICE_ACCOUNT_JSON=

# Stdout verbose del módulo sheets.
# SHEETS_DEBUG=1
